# CineScope — Environment Variables
# Copy this to .env and fill in your values.
# .env is gitignored — never commit real secrets to git.

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────
# Default is SQLite at /data/cinescope.db (inside the container)
# You usually don't need to change this.
DATABASE_URL=sqlite+aiosqlite:////data/cinescope.db

# ── Plex ────────────────────────────────────────────────────
# Your Plex server URL. If running CineScope in Docker on the same
# machine as Plex, use host.docker.internal instead of localhost.
PLEX_URL=http://host.docker.internal:32400

# How to find your Plex token:
# 1. Open Plex Web in your browser
# 2. Browse to any movie, click the "..." menu > Get Info
# 3. Click "View XML" at the bottom
# 4. Look for X-Plex-Token= in the URL
PLEX_TOKEN=your_plex_token_here

# The exact name of your Movies library (check Plex > Libraries)
PLEX_MOVIE_LIBRARY=Movies

# ── Radarr ──────────────────────────────────────────────────
RADARR_URL=http://host.docker.internal:7878

# Find in Radarr: Settings > General > Security > API Key
RADARR_API_KEY=your_radarr_api_key_here

# ── Discovery ────────────────────────────────────────────────
# How often (hours) to check sources for new films
DISCOVERY_INTERVAL_HOURS=6
